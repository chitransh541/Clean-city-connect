# Database Configuration
# Local Development
PGUSER=postgres
PGPASSWORD=your_local_password
PGHOST=localhost
PGPORT=5432
PGDATABASE=cleancity

# Production Database (Supabase, Neon, Render)
# If provided, this overrides the PG* variables above
# DATABASE_URL=postgresql://user:password@host:port/dbname

# Authentication
JWT_SECRET=your_super_secret_jwt_key

# Admin User Defaults (Used by init-db.js)
ADMIN_PHONE=+911234567890
ADMIN_PASSWORD=your_secure_admin_password

# Cloudinary (Media Storage)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# AI Vision (Hugging Face Inference)
# HF_API_KEY=your_huggingface_token
# HF_MODEL=Qwen/Qwen3.5-9B:together

# Twilio (SMS Verification)
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=your_twilio_phone

# Server Configuration
PORT=5000
# FRONTEND_URL=https://your-frontend-domain.vercel.app
